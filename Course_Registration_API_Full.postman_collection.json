		{
			"name": "5. Payments – Razorpay",
			"description": "Full payment flow:\n1. Get Razorpay Key\n2. Create Order for a paid course\n3. Complete payment on Razorpay checkout (client-side)\n4. Verify Payment → auto-enrolls the student\n5. View payment history",
			"item": [
				{
					"name": "Get Razorpay Key",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/payments/key",
							"host": ["{{baseUrl}}"],
							"path": ["payments", "key"]
						}
					},
					"description": "Returns the Razorpay key_id needed by the client-side checkout."
				},
				{
					"name": "Create Order (Paid Course)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.order && res.order.id) {",
									"    pm.collectionVariables.set('razorpayOrderId', res.order.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/payments/order/{{courseId}}",
							"host": ["{{baseUrl}}"],
							"path": ["payments", "order", "{{courseId}}"]
						}
					},
					"description": "Creates a Razorpay order. The `order.id`, `order.amount`, and `key` from the response are passed to Razorpay checkout on the frontend."
				},
				{
					"name": "Verify Payment",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"razorpay_order_id\": \"{{razorpayOrderId}}\",\n    \"razorpay_payment_id\": \"{{razorpayPaymentId}}\",\n    \"razorpay_signature\": \"{{razorpaySignature}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/payments/verify",
							"host": ["{{baseUrl}}"],
							"path": ["payments", "verify"]
						}
					},
					"description": "Send the razorpay_order_id, razorpay_payment_id, and razorpay_signature received from the Razorpay checkout callback. On success, the student is automatically enrolled in the course."
				},
				{
					"name": "Get My Payments",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/payments/my-payments",
							"host": ["{{baseUrl}}"],
							"path": ["payments", "my-payments"]
						}
					}
				}
			]
		},
