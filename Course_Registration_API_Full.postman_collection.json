							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"oldPassword\": \"password123\",\n    \"newPassword\": \"newpassword123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/change-password",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "change-password"]
						}
					}
